generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("TECHNICIAN")
  createdAt DateTime @default(now())
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  dni       String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model Sale {
  id               Int        @id @default(autoincrement())
  correlativeId    String     @unique
  clientId         String?
  dni              String
  names            String
  address          String
  phone            String
  locationLink     String     @db.Text
  referencePhotos  String     @db.LongText
  status           String     @default("PENDING")
  sellerNameOrId   String
  installedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Attendance {
  id           Int      @id @default(autoincrement())
  employeeId   Int?
  userName     String
  dni          String?
  photoUrl     String   @db.LongText
  latitude     Float
  longitude    Float
  createdAt    DateTime @default(now())
}
